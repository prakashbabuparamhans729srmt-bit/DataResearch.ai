
{
  "entities": {
    "AdminUser": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AdminUser",
      "type": "object",
      "description": "Represents an authorized administrator with system-wide privileges.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase Auth UID of the administrator."
        },
        "displayName": {
          "type": "string",
          "description": "Public name of the admin."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email of the admin."
        },
        "role": {
          "type": "string",
          "description": "System role (e.g., 'A to Z Administrator')."
        },
        "theme": {
          "type": "string",
          "enum": ["light", "dark", "system"]
        },
        "autoSync": {
          "type": "boolean"
        },
        "neuralInsights": {
          "type": "boolean"
        },
        "language": {
          "type": "string"
        },
        "securityLevel": {
          "type": "string"
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["uid", "email"]
    },
    "Student": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Student",
      "type": "object",
      "description": "Represents a student enrolled in the data research program.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "gender": {
          "type": "string",
          "enum": ["Male", "Female", "Other"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "attendancePercentage": {
          "type": "number"
        },
        "averageScorePercentage": {
          "type": "number"
        },
        "completionPercentage": {
          "type": "number"
        },
        "rank": {
          "type": "number"
        },
        "status": {
          "type": "string",
          "enum": ["Active", "Idle"]
        },
        "trends": {
          "type": "array",
          "items": { "type": "number" }
        }
      },
      "required": ["id", "name", "gender", "attendancePercentage", "averageScorePercentage", "status"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "/admin_users/{adminId}": {
      "schema": "#/entities/AdminUser",
      "description": "System administrators directory."
    },
    "/students/{studentId}": {
      "schema": "#/entities/Student",
      "description": "Global student research nodes."
    }
  }
}
